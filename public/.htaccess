# BEGIN WordPress
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# Allow WordPress REST API
RewriteRule ^wp-json/(.*) /wp-json/$1 [L]

# Allow WordPress admin and core files
RewriteRule ^wp-admin(.*)$ /wp-admin$1 [L]
RewriteRule ^wp-login\.php$ /wp-login.php [L]
RewriteRule ^wp-content/(.*)$ /wp-content/$1 [L]
RewriteRule ^wp-includes/(.*)$ /wp-includes/$1 [L]
RewriteRule ^wp-cron\.php$ /wp-cron.php [L]
RewriteRule ^xmlrpc\.php$ /xmlrpc.php [L]

# Allow WooCommerce pages (handled by WordPress)
RewriteRule ^shop(.*)$ /index.php [L]
RewriteRule ^cart(.*)$ /index.php [L]
RewriteRule ^checkout(.*)$ /index.php [L]
RewriteRule ^my-account(.*)$ /index.php [L]
RewriteRule ^product(.*)$ /index.php [L]
RewriteRule ^\?add-to-cart= /index.php [L]
RewriteRule ^\?wc-api= /index.php [L]

# Allow WordPress permalink handling for blog posts
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^blog/(.+)$ /index.php [L]

# Serve static files from the React build if they exist
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^(.*)$ $1 [L]

# For all other non-file, non-directory requests, serve React's index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /index.html [L]
</IfModule>
# END WordPress
