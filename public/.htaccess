# BEGIN WordPress
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# WordPress core files — pass directly to PHP
RewriteRule ^wp-login\.php$ - [L]
RewriteRule ^wp-cron\.php$ - [L]
RewriteRule ^xmlrpc\.php$ - [L]

# WordPress directories — pass through without rewriting
RewriteRule ^wp-admin(.*)$ - [L]
RewriteRule ^wp-content/(.*)$ - [L]
RewriteRule ^wp-includes/(.*)$ - [L]

# WordPress REST API
RewriteRule ^wp-json(/.*)?$ /index.php [L]

# WooCommerce pages (handled by WordPress)
RewriteRule ^shop(/.*)?$ /index.php [L]
RewriteRule ^cart(/.*)?$ /index.php [L]
RewriteRule ^checkout(/.*)?$ /index.php [L]
RewriteRule ^my-account(/.*)?$ /index.php [L]
RewriteRule ^product(/.*)?$ /index.php [L]
RewriteRule ^product-category(/.*)?$ /index.php [L]

# WooCommerce AJAX/API
RewriteCond %{QUERY_STRING} wc-api= [OR]
RewriteCond %{QUERY_STRING} add-to-cart= [OR]
RewriteCond %{QUERY_STRING} removed_item= [OR]
RewriteCond %{QUERY_STRING} wc-ajax=
RewriteRule ^(.*)$ /index.php [L]

# WordPress blog posts (handled by WordPress)
RewriteRule ^blog/(.+)$ /index.php [L]

# Serve existing static files directly (React build assets, images, etc.)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^(.*)$ - [L]

# Everything else goes to React's index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /index.html [L]
</IfModule>
# END WordPress
